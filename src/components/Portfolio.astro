---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { KATEGORIEN } from '../data/kategorien';

/**
 * Alle Bilder und Videos aus src/bilder/<kategorie>/ werden automatisch
 * eingesammelt. Neue Dateien einfach in den passenden Ordner legen —
 * der Dateiname (ohne Endung) wird zum Alt-Text.
 */
const bildModule = import.meta.glob<{ default: ImageMetadata }>(
  '../bilder/*/*.{jpg,jpeg,png,webp,avif,svg}',
  { eager: true }
);
const videoModule = import.meta.glob<string>('../bilder/*/*.mp4', {
  eager: true,
  query: '?url',
  import: 'default',
});

function zerlegePfad(pfad: string) {
  const teile = pfad.split('/');
  const kategorie = teile[teile.length - 2];
  const dateiname = teile[teile.length - 1].replace(/\.[^.]+$/, '');
  const alt = dateiname
    .replace(/[-_]+/g, ' ')
    .replace(/\b\p{L}/gu, (b) => b.toUpperCase());
  return { kategorie, alt, sortier: pfad };
}

type Eintrag =
  | { typ: 'bild'; kategorie: string; alt: string; sortier: string; bild: ImageMetadata }
  | { typ: 'video'; kategorie: string; alt: string; sortier: string; url: string };

const reihenfolge = new Map(KATEGORIEN.map((k, i) => [k.slug, i]));
const labels = new Map(KATEGORIEN.map((k) => [k.slug, k.kurz]));

const eintraege: Eintrag[] = [
  ...Object.entries(bildModule).map(([pfad, mod]) => ({
    typ: 'bild' as const,
    ...zerlegePfad(pfad),
    bild: mod.default,
  })),
  ...Object.entries(videoModule).map(([pfad, url]) => ({
    typ: 'video' as const,
    ...zerlegePfad(pfad),
    url,
  })),
].sort(
  (a, b) =>
    (reihenfolge.get(a.kategorie) ?? 99) - (reihenfolge.get(b.kategorie) ?? 99) ||
    a.sortier.localeCompare(b.sortier)
);
---

<section id="portfolio" class="section" aria-labelledby="portfolio-titel">
  <div class="container">
    <div data-reveal>
      <p class="section-kicker">Portfolio</p>
      <h2 id="portfolio-titel">Ausgewählte Arbeiten</h2>
      <p class="section-intro">
        Ein Querschnitt aus Porträts, Kampagnenmotiven, Printprodukten und Bewegtbild.
        Nutzen Sie die Filter, um gezielt in einen Bereich einzutauchen.
      </p>
    </div>

    <div class="filter-leiste" role="group" aria-label="Portfolio nach Kategorie filtern" data-reveal>
      <button type="button" class="filter-btn" data-filter-btn="alle" aria-pressed="true">
        Alle
      </button>
      {KATEGORIEN.map((kategorie) => (
        <button
          type="button"
          class="filter-btn"
          data-filter-btn={kategorie.slug}
          aria-pressed="false"
        >
          {kategorie.kurz}
        </button>
      ))}
    </div>

    <div class="galerie" data-reveal>
      {eintraege.map((eintrag) => (
        <figure class="galerie-element" data-kategorie={eintrag.kategorie}>
          {eintrag.typ === 'bild' ? (
            <Image src={eintrag.bild} alt={eintrag.alt} loading="lazy" />
          ) : (
            <video
              src={eintrag.url}
              muted
              loop
              playsinline
              controls
              preload="metadata"
              aria-label={eintrag.alt}
            />
          )}
          <figcaption>
            <span class="element-kategorie">{labels.get(eintrag.kategorie) ?? eintrag.kategorie}</span>
            <span class="element-titel">{eintrag.alt}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="galerie-leer" hidden>In dieser Kategorie sind noch keine Beispiele hinterlegt.</p>
  </div>
</section>

<style>
  .filter-leiste {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 2.5rem;
  }

  .filter-btn {
    min-height: 2.75rem;
    padding: 0.5rem 1.2rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      color var(--dur-micro) var(--ease-out),
      border-color var(--dur-micro) var(--ease-out),
      background-color var(--dur-micro) var(--ease-out);
  }

  .filter-btn:hover {
    color: var(--fg);
    border-color: rgba(124, 138, 255, 0.5);
  }

  .filter-btn[aria-pressed='true'] {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
    color: #fff;
  }

  .galerie {
    column-count: 3;
    column-gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .galerie-element {
    break-inside: avoid;
    margin: 0 0 1.25rem;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    position: relative;
  }

  .galerie-element[hidden] {
    display: none;
  }

  .galerie-element :global(img),
  .galerie-element video {
    width: 100%;
    transition: transform 450ms var(--ease-out);
  }

  .galerie-element:hover :global(img) {
    transform: scale(1.03);
  }

  .galerie-element figcaption {
    position: absolute;
    inset: auto 0 0 0;
    padding: 2.25rem 1.1rem 0.95rem;
    background: linear-gradient(180deg, transparent, rgba(5, 5, 8, 0.88));
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    opacity: 0;
    transition: opacity 300ms var(--ease-out);
    pointer-events: none;
  }

  .galerie-element:hover figcaption,
  .galerie-element:focus-within figcaption {
    opacity: 1;
  }

  .element-kategorie {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .element-titel {
    font-size: 0.95rem;
    /* Liegt immer auf dunklem Bild-Verlauf — unabhängig vom Theme hell */
    color: #ececf1;
  }

  .galerie-leer {
    margin-top: 2rem;
    color: var(--fg-muted);
    text-align: center;
    max-width: none;
  }

  @media (max-width: 900px) {
    .galerie {
      columns: 2;
    }
  }

  @media (max-width: 560px) {
    .galerie {
      columns: 1;
    }

    /* Auf Touch-Geräten gibt es kein Hover — Bildunterschrift immer zeigen */
    .galerie-element figcaption {
      opacity: 1;
    }
  }
</style>

<script>
  const knoepfe = document.querySelectorAll<HTMLButtonElement>('[data-filter-btn]');
  const elemente = document.querySelectorAll<HTMLElement>('.galerie-element');
  const leerHinweis = document.querySelector<HTMLElement>('.galerie-leer');

  function filtern(slug: string) {
    let sichtbar = 0;
    elemente.forEach((el) => {
      const passt = slug === 'alle' || el.dataset.kategorie === slug;
      el.hidden = !passt;
      if (passt) sichtbar++;
    });
    knoepfe.forEach((k) =>
      k.setAttribute('aria-pressed', String(k.dataset.filterBtn === slug))
    );
    if (leerHinweis) leerHinweis.hidden = sichtbar > 0;
  }

  knoepfe.forEach((k) =>
    k.addEventListener('click', () => filtern(k.dataset.filterBtn ?? 'alle'))
  );

  // Links aus den Leistungs-Karten ("Beispiele ansehen") setzen den Filter direkt
  document.querySelectorAll<HTMLElement>('[data-filter-link]').forEach((link) =>
    link.addEventListener('click', () => filtern(link.dataset.filterLink ?? 'alle'))
  );
</script>
