---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/600-italic.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Onepage-Navigation (Anker) nur auf der Startseite anzeigen */
  onepage?: boolean;
}

const { title, description, onepage = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'blickmacherei',
  url: Astro.site?.toString(),
  description:
    'Studio für ultrarealistische Porträts, Markenwelten, Avatare und Video — von der Idee bis zum fertigen Motiv.',
  email: 'kontakt@blickmacherei.de',
  areaServed: 'DE',
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="blickmacherei" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />
    <meta name="twitter:card" content="summary" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      // Läuft vor dem ersten Rendern, damit das Theme nicht "aufblitzt" (FOUC).
      // Reihenfolge: gespeicherte Wahl → Systemeinstellung → Dark (Standard).
      (() => {
        let theme = 'dark';
        try {
          theme =
            localStorage.getItem('theme') ||
            (matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        } catch {}
        document.documentElement.dataset.theme = theme;
      })();

      // Kennzeichnet aktives JavaScript — nur dann werden Reveal-Animationen aktiviert,
      // damit die Seite ohne JS niemals unsichtbar bleibt.
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a href="#inhalt" class="skip-link">Zum Inhalt springen</a>

    <!-- Seitenweiter, dezenter Neon-Flow-Hintergrund (Three.js, lokal gehostet).
         Liegt fixiert HINTER allen Inhalten (z-index -1) und scheint überall
         dort durch, wo Sektionen keinen eigenen opaken Hintergrund haben. -->
    <div class="neon-flow" aria-hidden="true">
      <canvas id="neon-flow-canvas"></canvas>
    </div>

    <Header onepage={onepage} />
    <main id="inhalt">
      <slot />
    </main>
    <Footer />

    <script>
      // --- Neon-Flow-Hintergrund (seitenweit, dezent) ------------------------
      // Lädt das lokal gehostete Three.js-Bundle (~250 KB gzipped) erst bei der
      // ersten Mausbewegung — der Effekt ist cursorgesteuert, ohne Maus wäre er
      // nutzlos. So kostet er weder LCP noch mobile Datenvolumen.
      const neonEbene = document.querySelector<HTMLElement>('.neon-flow');
      const neonCanvas = document.getElementById('neon-flow-canvas') as HTMLCanvasElement | null;

      const neonSinnvoll =
        neonEbene &&
        neonCanvas &&
        matchMedia('(pointer: fine)').matches &&
        !matchMedia('(prefers-reduced-motion: reduce)').matches &&
        !(navigator as any).connection?.saveData;

      if (neonSinnvoll) {
        const starten = async () => {
          try {
            // URL zur Laufzeit bauen, damit Vite den Public-Import nicht anfasst —
            // der Browser lädt das Bundle nativ als ES-Modul.
            const bundleUrl = new URL('/js/tubes1.min.js', window.location.origin).href;
            const modul = await import(/* @vite-ignore */ bundleUrl);
            modul.default(neonCanvas, {
              tubes: {
                // Markenfarben statt Neon-Regenbogen — bewusst zurückhaltend
                colors: ['#5e6ad2', '#7c8aff', '#3b4394'],
                lights: {
                  intensity: 60,
                  colors: ['#5e6ad2', '#8a5ed2', '#4aa8d8', '#7c8aff'],
                },
              },
            });
            neonEbene.classList.add('aktiv');
          } catch (fehler) {
            // Reine Dekoration — Fehler still schlucken, Seite läuft weiter
            console.warn('Neon-Flow konnte nicht geladen werden:', fehler);
          }
        };

        window.addEventListener('pointermove', () => starten(), { once: true });
      }

      // Sanftes Einblenden beim Scrollen — respektiert prefers-reduced-motion.
      const reduziert = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const elemente = document.querySelectorAll<HTMLElement>('[data-reveal]');

      if (!reduziert && 'IntersectionObserver' in window) {
        const beobachter = new IntersectionObserver(
          (eintraege) => {
            for (const eintrag of eintraege) {
              if (eintrag.isIntersecting) {
                eintrag.target.classList.add('in-view');
                beobachter.unobserve(eintrag.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.1 }
        );
        elemente.forEach((el) => beobachter.observe(el));
      } else {
        elemente.forEach((el) => el.classList.add('in-view'));
      }
    </script>
  </body>
</html>
